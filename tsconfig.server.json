{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": "src",
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["src/server", "src/shared"]
}
